{
  "name": "kessoku-the-shot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "init": "pnpm i --lockfile && npx cap add ios && npx cap add android && node scripts/add-permissions.js && npx cap sync",
    "dev": "vite",
    "sync": "npx cap sync",
    "build": "vite build",
    "permission": "node scripts/add-permissions.js",
    "start:ios": "NODE_ENV=production pnpm build && npx cap sync ios && npx cap run ios",
    "start:android": "NODE_ENV=production pnpm build && npx cap sync android && npx cap run android",
    "release:apk": "pnpm build && npx cap sync android && cd android && ./gradlew assembleRelease && cd ..",
    "build:bundle": "pnpm build && npx cap sync android && cd android && ./gradlew bundleRelease && cd ..",
    "icon": "npx @capacitor/assets generate",
    "open": "cd /Users/atrior/GitHub/Kessoku-the-Shot/android/app/build/outputs/apk/release && open ."
  },
  "dependencies": {
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/screen-orientation": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@vant/touch-emulator": "^1.5.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "fs": "0.0.1-security",
    "less": "^4.2.2",
    "lucide-vue-next": "^0.562.0",
    "mediasoup-client": "3",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3",
    "typescript": "5.4.5",
    "vant": "^4.9.22",
    "vite": "^7.1.7",
    "vite-plugin-mkcert": "^1.17.9",
    "vue": "^3.2.31",
    "vue-class-component": "^8.0.0-rc.1",
    "vue-property-decorator": "^10.0.0-rc.3",
    "vue-router": "^4.6.4",
    "vue-tsc": "1.8.27"
  }
}
